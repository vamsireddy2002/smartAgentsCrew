<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <description>A4 — Routes outbound WhatsApp template messages. IMPORTANT: After setting up Salesforce Digital Engagement and activating the Electra_WhatsApp_Channel, open each decision path in Flow Builder and replace the placeholder action with the actual "Send Messaging Notification" core action pointing to your approved template.</description>
    <interviewLabel>SendWhatsAppMessage {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SendWhatsAppMessage</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value><stringValue>LightningFlowBuilder</stringValue></value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>

    <!-- ═══ STEP 1: Which template should be sent? ═══ -->
    <decisions>
        <name>Which_Template</name>
        <label>Which Template To Send?</label>
        <locationX>176</locationX>
        <locationY>168</locationY>
        <defaultConnector>
            <targetReference>Mark_Send_Failed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Unknown Template</defaultConnectorLabel>
        <rules>
            <name>OTP_Verification</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>templateName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue><stringValue>OTPVerification</stringValue></rightValue>
            </conditions>
            <connector>
                <targetReference>Send_OTP_Notification</targetReference>
            </connector>
            <label>OTPVerification</label>
        </rules>
        <rules>
            <name>Test_Drive_Confirmation</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>templateName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue><stringValue>TestDriveConfirmation</stringValue></rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Confirmation_Notification</targetReference>
            </connector>
            <label>TestDriveConfirmation</label>
        </rules>
        <rules>
            <name>Cancellation_Confirmation</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>templateName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue><stringValue>CancellationConfirmation</stringValue></rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Cancellation_Notification</targetReference>
            </connector>
            <label>CancellationConfirmation</label>
        </rules>
        <rules>
            <name>Reschedule_Confirmation</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>templateName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue><stringValue>RescheduleConfirmation</stringValue></rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Reschedule_Notification</targetReference>
            </connector>
            <label>RescheduleConfirmation</label>
        </rules>
    </decisions>

    <!--
    ═══════════════════════════════════════════════════════════════════════
    PLACEHOLDER ACTIONS — After Digital Engagement is configured:
    1. Open this flow in Flow Builder
    2. Delete these placeholder assignments
    3. Add a "Send Notification" or "Send Messaging Notification" Core Action
    4. Connect it to Electra_WhatsApp_Channel + the approved template
    5. Map param1-param5 to the template variables
    ═══════════════════════════════════════════════════════════════════════
    -->

    <!-- Path: OTPVerification — replace with actual WhatsApp send action -->
    <assignments>
        <name>Send_OTP_Notification</name>
        <label>PLACEHOLDER — Send OTP WhatsApp (configure after DE setup)</label>
        <locationX>176</locationX>
        <locationY>288</locationY>
        <assignmentItems>
            <assignToReference>success</assignToReference>
            <operator>Assign</operator>
            <value><booleanValue>true</booleanValue></value>
        </assignmentItems>
        <connector>
            <targetReference>Mark_Send_Succeeded</targetReference>
        </connector>
    </assignments>

    <!-- Path: TestDriveConfirmation — replace with actual WhatsApp send action -->
    <assignments>
        <name>Send_Confirmation_Notification</name>
        <label>PLACEHOLDER — Send Booking Confirmation WhatsApp (configure after DE setup)</label>
        <locationX>440</locationX>
        <locationY>288</locationY>
        <assignmentItems>
            <assignToReference>success</assignToReference>
            <operator>Assign</operator>
            <value><booleanValue>true</booleanValue></value>
        </assignmentItems>
        <connector>
            <targetReference>Mark_Send_Succeeded</targetReference>
        </connector>
    </assignments>

    <!-- Path: CancellationConfirmation — replace with actual WhatsApp send action -->
    <assignments>
        <name>Send_Cancellation_Notification</name>
        <label>PLACEHOLDER — Send Cancellation WhatsApp (configure after DE setup)</label>
        <locationX>700</locationX>
        <locationY>288</locationY>
        <assignmentItems>
            <assignToReference>success</assignToReference>
            <operator>Assign</operator>
            <value><booleanValue>true</booleanValue></value>
        </assignmentItems>
        <connector>
            <targetReference>Mark_Send_Succeeded</targetReference>
        </connector>
    </assignments>

    <!-- Path: RescheduleConfirmation — replace with actual WhatsApp send action -->
    <assignments>
        <name>Send_Reschedule_Notification</name>
        <label>PLACEHOLDER — Send Reschedule WhatsApp (configure after DE setup)</label>
        <locationX>960</locationX>
        <locationY>288</locationY>
        <assignmentItems>
            <assignToReference>success</assignToReference>
            <operator>Assign</operator>
            <value><booleanValue>true</booleanValue></value>
        </assignmentItems>
        <connector>
            <targetReference>Mark_Send_Succeeded</targetReference>
        </connector>
    </assignments>

    <!-- Success assignment -->
    <assignments>
        <name>Mark_Send_Succeeded</name>
        <label>Mark Send as Succeeded</label>
        <locationX>440</locationX>
        <locationY>408</locationY>
        <assignmentItems>
            <assignToReference>success</assignToReference>
            <operator>Assign</operator>
            <value><booleanValue>true</booleanValue></value>
        </assignmentItems>
    </assignments>

    <!-- Failure assignment -->
    <assignments>
        <name>Mark_Send_Failed</name>
        <label>Mark Send as Failed (Unknown Template)</label>
        <locationX>176</locationX>
        <locationY>408</locationY>
        <assignmentItems>
            <assignToReference>success</assignToReference>
            <operator>Assign</operator>
            <value><booleanValue>false</booleanValue></value>
        </assignmentItems>
    </assignments>

    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Which_Template</targetReference>
        </connector>
    </start>
    <status>Active</status>

    <!-- ═══ INPUT VARIABLES ═══ -->
    <variables>
        <name>phone</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>templateName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>param1</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>param2</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>param3</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>param4</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>param5</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>

    <!-- ═══ OUTPUT VARIABLES ═══ -->
    <variables>
        <name>success</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
        <value><booleanValue>false</booleanValue></value>
    </variables>
</Flow>
